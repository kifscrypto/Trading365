//@version=6
// ============================================================================
// Trading365 Scanner — live model as a TradingView strategy
// ----------------------------------------------------------------------------
// A faithful visual port of the production scanner (app/api/scanner/_core.ts +
// entries/long-entries routes). Lets you SEE the model on a chart and backtest
// it, rather than reading DB rows.
//
// Pipeline mirrored 1:1:
//   1. 4H SCORING      scoreKlines (short) / scoreLongKlines (long)  → raw score
//   2. BTC REGIME      4H price vs EMA50 with a ±1% deadband (the Jul-2026
//                      anti-whipsaw fix) → downtrend / neutral / uptrend
//   3. SENTIMENT DELTA short +1 in downtrend / −2 in uptrend; long inverted
//   4. 1H ENTRY GATE   shorts need 2-of-3 triggers, longs 1-of-3, AND the
//                      regime must agree AND adjusted score ≥ threshold
//   5. RISK            stop = last swing high/low clamped to 2–4% from entry;
//                      5-tier scale-out at 1.5 / 2.5 / 4 / 6 / 8%
//
// ⚠ APPLY TO A 1H CHART. Scoring/regime are pulled from 4H + Daily via
//   request.security; the entry triggers evaluate on the 1H (chart) timeframe,
//   exactly as the live /entries cron does hourly against a 4H watchlist.
//
// TradingView limitations vs. the live scanner (documented, not hidden):
//   • No funding-rate feed on TV. Funding contributes 0–3 pts (short) / 0–2
//     (long) live; here it's an input you can set to your assumed regime.
//   • No FNG / BTC-dominance feeds. Live, these are *confirmatory only* and can
//     never override 4H structure, so the regime gate reduces to pure structure
//     — which for SHORTS is exact (downtrend ⟺ BTC 4H close < EMA50·0.99).
//   • Single symbol; no multi-exchange OI ranking or the altcoin-decoupling
//     circuit breaker (those are portfolio-level, not per-chart).
// ============================================================================

strategy("Trading365 Scanner Model", overlay=true, pyramiding=0,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     initial_capital=10000, commission_type=strategy.commission.percent,
     commission_value=0.05, calc_on_every_tick=false)

// ─────────────────────────────── Inputs ───────────────────────────────
dir            = input.string("Short", "Direction", options=["Short","Long"], group="Model")
btcSym         = input.symbol("BINANCE:BTCUSDT", "BTC symbol (regime driver)", group="Model")
deadbandPct    = input.float(1.0, "BTC regime deadband (%)", minval=0.0, step=0.25, group="Model",
                     tooltip="BTC must be more than this % beyond its 4H EMA50 to count as bull/bear. Inside the band = neutral (no trades). Live default 1.0%.") / 100.0
thrShort       = input.int(7, "Short entry threshold (adj score ≥)", minval=1, maxval=15, group="Model")
thrLong        = input.int(8, "Long entry threshold (adj score ≥)",  minval=1, maxval=15, group="Model")
bypassRegime   = input.bool(false, "Debug: ignore BTC regime gate", group="Model",
                     tooltip="Fire on score + triggers ALONE, ignoring the downtrend/uptrend requirement. Turn ON to confirm the engine produces trades; the live scanner never does this.")
fundShortPts   = input.int(0, "Assumed funding pts — short (0–3)", minval=0, maxval=3, group="Model",
                     tooltip="TV has no funding feed. Live: +3 funding>0.05%, +2 >0.01%, +1 >0. Set your assumed regime.")
fundLongPts    = input.int(0, "Assumed funding pts — long (0–2)",  minval=0, maxval=2, group="Model",
                     tooltip="Live longs: +2 funding<0, +1 funding<0.01%. Longs are cheap when funding is low/negative.")

// Risk / scale-out
stopMinPct     = input.float(2.0, "Stop min dist (%)", group="Risk") / 100.0
stopMaxPct     = input.float(4.0, "Stop max dist (%)", group="Risk") / 100.0
tp1p = input.float(1.5, "TP1 %", group="Targets") / 100.0
tp2p = input.float(2.5, "TP2 %", group="Targets") / 100.0
tp3p = input.float(4.0, "TP3 %", group="Targets") / 100.0
tp4p = input.float(6.0, "TP4 %", group="Targets") / 100.0
tp5p = input.float(8.0, "TP5 %", group="Targets") / 100.0
tpSz = input.int(20, "Scale-out size per TP (%)", minval=1, maxval=100, group="Targets")

// ══════════════════════════ 4H SHORT SCORE ══════════════════════════
// Port of scoreKlines() — signals 1–7 (4H). Returns -1 to signal a hard skip
// (RSI < 30 oversold), matching the JS early-return.
f_short4h(int fundPts) =>
    e200 = ta.ema(close, 200)
    rsi  = ta.rsi(close, 14)
    rsi5 = rsi[5]
    [macdLine, signalLine, _h] = ta.macd(close, 12, 26, 9)
    int sc = 0
    // Signal 1 — EMA200 distance banding (0–2)
    if not na(e200)
        pctBelow = (e200 - close) / e200
        sc += pctBelow >= 0.25 ? 2 : pctBelow >= 0.10 ? 1 : 0
    // Signal 2 — 4H lower highs: avg(last10 highs) vs avg(prior10) (0–2)
    recentH = ta.sma(high, 10)
    prevH   = ta.sma(high, 10)[10]
    if not na(prevH) and prevH != 0
        drop = (prevH - recentH) / prevH
        sc += drop > 0.03 ? 2 : drop > 0 ? 1 : 0
    // Signal 3 — bear candles carry more volume, last 50 (0–2)
    float bearV = 0.0
    int   bearN = 0
    float bullV = 0.0
    int   bullN = 0
    for i = 0 to 49
        if close[i] < open[i]
            bearV += volume[i]
            bearN += 1
        else
            bullV += volume[i]
            bullN += 1
    ratio = (bearN > 0 and bullN > 0) ? (bearV / bearN) / (bullV / bullN) : 1.0
    sc += ratio > 1.20 ? 2 : ratio > 1 ? 1 : 0
    // Signal 4 — funding (external → input)
    sc += fundPts
    // Signal 5 — RSI: skip if oversold, +1 if overbought
    skip = rsi < 30
    sc += rsi > 70 ? 1 : 0
    // Signal 6 — bearish RSI divergence (0–2)
    recentLow = ta.lowest(low, 5)
    priorLow  = ta.lowest(low, 5)[5]
    if not na(priorLow) and recentLow > priorLow and rsi < rsi5
        sc += 2
    // Signal 7 — MACD (0–2)
    sc += macdLine < signalLine ? 1 : 0
    sc += (macdLine < 0 and signalLine < 0) ? 1 : 0
    skip ? -1 : sc

// Signal 8 — daily 200EMA + daily lower highs (0–2)
f_shortDaily() =>
    dE200 = ta.ema(close, 200)
    int p = 0
    p += (not na(dE200) and close < dE200) ? 1 : 0
    rH = ta.sma(high, 10)
    pH = ta.sma(high, 10)[10]
    p += (not na(pH) and pH != 0 and (pH - rH) / pH > 0.03) ? 1 : 0
    p

// ══════════════════════════ 4H LONG SCORE ══════════════════════════
// Port of scoreLongKlines() 4H section. Returns [pts, rsi4h, distPct] so the
// confluence bonus (needs daily-bullish flag) can be applied on assembly.
f_long4h(int fundPts) =>
    e50  = ta.ema(close, 50)
    e200 = ta.ema(close, 200)
    rsi  = ta.rsi(close, 14)
    [m, s, _h] = ta.macd(close, 12, 26, 9)
    distPct = (not na(e200) and e200 > 0) ? (close - e200) / e200 * 100.0 : na
    int sc = 0
    // pullback zone: below 4H 50EMA but holding above 4H 200EMA
    if not na(e50) and not na(e200) and close < e50 and close > e200
        sc += 2
    if not na(distPct) and distPct > 0
        sc += distPct <= 3 ? 2 : distPct <= 6 ? 1 : 0
    sc += rsi < 40 ? 2 : rsi < 50 ? 1 : 0
    // MACD pulling back but still bullish
    if (m - s) < (m[1] - s[1]) and m > 0
        sc += 1
    // volume — a healthy pullback comes on FALLING volume
    avg20 = ta.sma(volume, 20)
    sc += (not na(avg20) and volume < avg20) ? 1 : 0
    down3 = close < open and close[1] < open[1] and close[2] < open[2]
    sc += (down3 and volume < volume[1] and volume[1] < volume[2]) ? 1 : 0
    // funding (external → input)
    sc += fundPts
    [sc, rsi, distPct]

// Daily context + non-negotiable trend gate. Returns [gatePass, pts, bullish].
// gatePass=false → the setup is skipped entirely (never long a daily downtrend).
f_longDaily() =>
    dE200 = ta.ema(close, 200)
    dE100 = ta.ema(close, 100)
    dE50  = ta.ema(close, 50)
    // ascending lows across three 5-bar daily windows (hoisted out of the branch
    // so ta.* is evaluated every bar — Pine requires consistent calls)
    w0 = ta.lowest(low, 5)[10]
    w1 = ta.lowest(low, 5)[5]
    w2 = ta.lowest(low, 5)
    trend = not na(dE200) ? dE200 : dE100
    applic = not na(trend)
    bullish = applic and close > trend
    gatePass = applic ? close > trend : true    // no daily data → gate N/A (mirror JS >=100 guard)
    int p = 0
    if bullish
        p += 2
        p += (not na(dE50) and dE50 > trend) ? 1 : 0
        p += (not na(w0) and w2 > w1 and w1 > w0) ? 1 : 0
    [gatePass, p, bullish]

// ─────────────── Pull HTF/Daily series via request.security ───────────────
s4h   = request.security(syminfo.tickerid, "240", f_short4h(fundShortPts))
sDayP = request.security(syminfo.tickerid, "1D",  f_shortDaily())
[l4h, lRsi4h, lDist4h] = request.security(syminfo.tickerid, "240", f_long4h(fundLongPts))
[lGate, lDayP, lDayBull] = request.security(syminfo.tickerid, "1D", f_longDaily())
e50_4h  = request.security(syminfo.tickerid, "240", ta.ema(close, 50))
e200_4h = request.security(syminfo.tickerid, "240", ta.ema(close, 200))

// BTC 4H regime driver
btc4hClose = request.security(btcSym, "240", close)
btc4hE50   = request.security(btcSym, "240", ta.ema(close, 50))
structBear = not na(btc4hE50) and btc4hClose < btc4hE50 * (1.0 - deadbandPct)
structBull = not na(btc4hE50) and btc4hClose > btc4hE50 * (1.0 + deadbandPct)
downtrend  = structBear
uptrend    = structBull
regime     = downtrend ? "downtrend" : uptrend ? "uptrend" : "neutral"

// ─────────────────────── Assemble adjusted scores ───────────────────────
// SHORT: raw = 4H(1–7) + daily(8); delta +1 downtrend / −2 uptrend; clamp 0–15
rawShort = s4h < 0 ? na : s4h + sDayP
adjShort = na(rawShort) ? na : math.max(0, math.min(15, rawShort + (downtrend ? 1 : uptrend ? -2 : 0)))

// LONG: gate first; confluence bonus needs daily-bullish flag
lConf    = (lDayBull and not na(lRsi4h) and lRsi4h < 45 and not na(lDist4h) and lDist4h >= 0 and lDist4h <= 5) ? 2 : 0
rawLong  = not lGate ? na : l4h + lDayP + lConf
adjLong  = na(rawLong) ? na : math.max(0, math.min(15, rawLong + (uptrend ? 1 : downtrend ? -2 : 0)))

// ─────────────── 1H entry triggers (chart timeframe, native) ───────────────
rsiC = ta.rsi(close, 14)
[mC, sC, _hc] = ta.macd(close, 12, 26, 9)

// Short: 2-of-3 (MACD bearish cross, RSI falling, bearish engulfing)
sMacdCross = ta.crossunder(mC, sC)
sRsiFall   = rsiC < 60 and rsiC < rsiC[3]
sEngulf    = close[1] > open[1] and close < open and open >= close[1] and close <= open[1]
sFired     = (sMacdCross ? 1 : 0) + (sRsiFall ? 1 : 0) + (sEngulf ? 1 : 0)

// Long: 1-of-3 (RSI turn-up off oversold, bull engulf near 200EMA, EMA bounce+HL)
lRsiTurn   = rsiC[3] < 40 and rsiC > rsiC[3]
bullEngulf = close[1] < open[1] and close > open and open <= close[1] and close >= open[1]
lEngulf200 = bullEngulf and not na(e200_4h) and e200_4h > 0 and math.abs(close - e200_4h) / e200_4h <= 0.05
// ta.* hoisted out of the short-circuit branches so they run every bar
ll5      = ta.lowest(low, 5)
llow3    = ta.lowest(low, 3)
llow3pri = ta.lowest(low[3], 5)
f_bounced(float ema, float ll) => not na(ema) and ema > 0 and ll <= ema * 1.015 and close > ema
lBounceHL  = (f_bounced(e50_4h, ll5) or f_bounced(e200_4h, ll5)) and llow3 > llow3pri
lFired     = (lRsiTurn ? 1 : 0) + (lEngulf200 ? 1 : 0) + (lBounceHL ? 1 : 0)

// ─────────────────────────── Entry decisions ───────────────────────────
goShort = dir == "Short" and (bypassRegime or downtrend) and not na(adjShort) and adjShort >= thrShort and sFired >= 2
goLong  = dir == "Long"  and (bypassRegime or uptrend)   and not na(adjLong)  and adjLong  >= thrLong  and lFired >= 1

// swing stop clamped to [min,max]% from entry (clampStop port)
f_clampShortStop(float entry) =>
    raw = ta.highest(high, 10)
    math.max(math.min(raw, entry * (1.0 + stopMaxPct)), entry * (1.0 + stopMinPct))
f_clampLongStop(float entry) =>
    raw = ta.lowest(low, 10)
    math.min(math.max(raw, entry * (1.0 - stopMaxPct)), entry * (1.0 - stopMinPct))

var float ePx = na
var float sPx = na

if goShort and strategy.position_size == 0
    strategy.entry("Short", strategy.short)
    ePx := close
    sPx := f_clampShortStop(close)
if goLong and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    ePx := close
    sPx := f_clampLongStop(close)

// 5-tier scale-out with the shared protective stop
if strategy.position_size < 0
    strategy.exit("TP1", "Short", qty_percent=tpSz, limit=ePx * (1 - tp1p), stop=sPx)
    strategy.exit("TP2", "Short", qty_percent=tpSz, limit=ePx * (1 - tp2p), stop=sPx)
    strategy.exit("TP3", "Short", qty_percent=tpSz, limit=ePx * (1 - tp3p), stop=sPx)
    strategy.exit("TP4", "Short", qty_percent=tpSz, limit=ePx * (1 - tp4p), stop=sPx)
    strategy.exit("TP5", "Short", qty_percent=tpSz, limit=ePx * (1 - tp5p), stop=sPx)
if strategy.position_size > 0
    strategy.exit("TP1", "Long", qty_percent=tpSz, limit=ePx * (1 + tp1p), stop=sPx)
    strategy.exit("TP2", "Long", qty_percent=tpSz, limit=ePx * (1 + tp2p), stop=sPx)
    strategy.exit("TP3", "Long", qty_percent=tpSz, limit=ePx * (1 + tp3p), stop=sPx)
    strategy.exit("TP4", "Long", qty_percent=tpSz, limit=ePx * (1 + tp4p), stop=sPx)
    strategy.exit("TP5", "Long", qty_percent=tpSz, limit=ePx * (1 + tp5p), stop=sPx)

// ─────────────────────────────── Visuals ───────────────────────────────
bgcolor(downtrend ? color.new(color.red, 92) : uptrend ? color.new(color.green, 92) : na, title="Regime")
plot(strategy.position_size != 0 ? ePx : na, "Entry", color.gray,  style=plot.style_linebr)
plot(strategy.position_size != 0 ? sPx : na, "Stop",  color.red,   style=plot.style_linebr)

curAdj = dir == "Short" ? adjShort : adjLong
plotchar(goShort, "Short entry", "▼", location.abovebar, color.red,   size=size.small)
plotchar(goLong,  "Long entry",  "▲", location.belowbar, color.green, size=size.small)

// ── Diagnostic HUD — tells you exactly why (or why not) a trade fires ──
btcOk       = not na(btc4hE50)
curThr      = dir == "Short" ? thrShort : thrLong
curFired    = dir == "Short" ? sFired : lFired
needFired   = dir == "Short" ? 2 : 1
regimeOk    = bypassRegime or (dir == "Short" ? downtrend : uptrend)
scoreOk     = not na(curAdj) and curAdj >= curThr
triggerOk   = curFired >= needFired
// Plain-English reason the current bar is NOT entering
blockReason = not btcOk         ? "BTC DATA MISSING — check symbol input" :
              not regimeOk       ? "regime ≠ " + (dir == "Short" ? "downtrend" : "uptrend") :
              na(curAdj)         ? "no score (RSI<30 skip / not enough bars)" :
              not scoreOk        ? "score " + str.tostring(curAdj) + " < " + str.tostring(curThr) :
              not triggerOk      ? "triggers " + str.tostring(curFired) + " < " + str.tostring(needFired) :
                                   "READY — entry conditions met"

bg = color.new(color.black, 70)
var table hud = table.new(position.top_right, 2, 6, border_width=1)
if barstate.islast
    table.cell(hud, 0, 0, "Trading365 " + dir, text_color=color.white, bgcolor=color.new(color.blue, 40))
    table.cell(hud, 1, 0, str.tostring(strategy.closedtrades) + " trades", text_color=color.white, bgcolor=color.new(color.blue, 40))
    table.cell(hud, 0, 1, "BTC feed", text_color=color.gray, bgcolor=bg)
    table.cell(hud, 1, 1, btcOk ? "OK" : "MISSING", text_color=btcOk ? color.lime : color.red, bgcolor=bg)
    table.cell(hud, 0, 2, "Regime", text_color=color.gray, bgcolor=bg)
    table.cell(hud, 1, 2, str.upper(regime) + (bypassRegime ? " (bypassed)" : ""), text_color=downtrend ? color.red : uptrend ? color.green : color.gray, bgcolor=bg)
    table.cell(hud, 0, 3, "Adj score", text_color=color.gray, bgcolor=bg)
    table.cell(hud, 1, 3, (na(curAdj) ? "—" : str.tostring(curAdj)) + " / " + str.tostring(curThr), text_color=scoreOk ? color.lime : color.orange, bgcolor=bg)
    table.cell(hud, 0, 4, "Triggers", text_color=color.gray, bgcolor=bg)
    table.cell(hud, 1, 4, str.tostring(curFired) + " / " + str.tostring(needFired), text_color=triggerOk ? color.lime : color.orange, bgcolor=bg)
    table.cell(hud, 0, 5, "Status", text_color=color.gray, bgcolor=bg)
    table.cell(hud, 1, 5, blockReason, text_color=blockReason == "READY — entry conditions met" ? color.lime : color.orange, bgcolor=bg)
